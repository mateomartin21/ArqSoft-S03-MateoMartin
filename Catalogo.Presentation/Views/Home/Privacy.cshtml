@{
    ViewData["Title"] = "Política de Privacidad";
}

<div class="container mt-5" style="max-width: 800px;">
    <h1 class="text-danger fw-bold text-center mb-4">@ViewData["Title"]</h1>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-4 p-md-5 text-muted">
            <h4 class="text-dark fw-bold mb-3">Seguridad de la Base de Datos</h4>
            <p>
                Toda la información registrada en esta Pokédex se utiliza exclusivamente con fines de investigación y clasificación. Nos comprometemos a mantener seguros tus datos como Entrenador.
            </p>

            <hr class="my-4">

            <h4 class="text-dark fw-bold mb-3">Uso de Cookies</h4>
            <p>
                Este sistema utiliza cookies esenciales para mantener tu sesión activa mientras exploras las diferentes generaciones y rutas. No compartimos tu información con organizaciones externas (¡ni con el Equipo Rocket!).
            </p>
        </div>
    </div>
</div>